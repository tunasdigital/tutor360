generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  // 🚀 F04: Removida a linha 'url' para cumprir a regra do Prisma 7.4.1 (Erro P1012)
  // A conexão agora é injetada automaticamente via process.env.DATABASE_URL
}

// 🔐 GAVETA ROOT: Gestão de Acesso
model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  password  String
  role      String   @default("ADMIN")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("users")
}

// 🎓 GAVETA PRINCIPAL: O Coração do Curso
model Course {
  id            String    @id @default(cuid())
  title         String
  slug          String    @unique
  description   String?   @db.Text
  thumbnail     String?
  category      String?
  
  // 💰 ATRIBUTOS COMERCIAIS (Mapeados da Curadoria)
  price         Float?    @default(0)
  discountPrice Float?    @default(0)
  level         String?   @default("Iniciante")
  isPublic      Boolean   @default(false)
  hasQnA        Boolean   @default(false)
  maxStudents   Int?      @default(0)
  duration      String?   
  
  // 🎥 F05 - VÍDEO DE VENDAS
  videoId       String?   

  // 🚀 F04 - REPETIDOR DE APRENDIZADO
  whatYouWillLearn String[] @default([]) 

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  
  // 🚀 F06 - HIERARQUIA ESTRUTURAL
  modules       Module[]  // Um curso agora tem vários módulos
  lessons       Lesson[]  // Mantido para legado/segurança das aulas antigas do WP

  @@map("courses")
}

// 📦 F06: A NOVA GAVETA INTERMEDIÁRIA (Módulos/Seções)
model Module {
  id          String   @id @default(cuid())
  title       String
  order       Int      @default(0) // Para ordenar (Módulo 1, Módulo 2)
  
  // Relação: A qual curso este módulo pertence?
  courseId    String
  course      Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  
  // Relação: Quais aulas estão dentro deste módulo?
  lessons     Lesson[] 

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("modules")
}

// 📖 GAVETA DE CONTEÚDO: Lições e Aulas
model Lesson {
  id        String   @id @default(cuid())
  title     String
  slug      String
  videoUrl  String
  duration  String?
  order     Int      @default(0)
  
  // Relação Maior: Curso
  courseId  String
  course    Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)

  // 🚀 F06: Relação Direta: Módulo (Opcional por enquanto para não quebrar as antigas)
  moduleId  String?
  module    Module?  @relation(fields: [moduleId], references: [id], onDelete: Cascade)

  wpId      Int?     @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("lessons")
}