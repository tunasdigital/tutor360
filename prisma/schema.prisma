generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Course {
  id          String   @id @default(cuid())
  title       String
  slug        String   @unique
  description String?
  thumbnail   String?
  category    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  lessons     Lesson[]

  @@map("courses")
}

model Lesson {
  id        String   @id @default(cuid())
  title     String
  slug      String
  videoUrl  String
  duration  String?
  order     Int      @default(0)
  courseId  String
  wpId      Int?     @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  course    Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@map("lessons")
}
