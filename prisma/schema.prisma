generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  // 🚀 F04: Removida a linha 'url' para cumprir a regra do Prisma 7.4.1 (Erro P1012)
  // A conexão agora é injetada automaticamente via process.env.DATABASE_URL
}

// 🔐 GAVETA ROOT: Gestão de Acesso
model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  password  String
  role      String   @default("ADMIN")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("users")
}

// 🎓 GAVETA PRINCIPAL: O Coração do Curso
model Course {
  id            String    @id @default(cuid())
  title         String
  slug          String    @unique
  description   String?   @db.Text
  thumbnail     String?
  category      String?
  
  // 💰 ATRIBUTOS COMERCIAIS (Mapeados da Curadoria)
  price         Float?    @default(0)
  discountPrice Float?    @default(0)
  level         String?   @default("Iniciante")
  isPublic      Boolean   @default(false)
  hasQnA        Boolean   @default(false)
  maxStudents   Int?      @default(0)
  duration      String?   
  
  // 🎥 F05 - VÍDEO DE VENDAS: Unificado para bater com as Actions (image_e6841d.png)
  videoId       String?   

  // 🚀 F04 - REPETIDOR DE APRENDIZADO: A gaveta de array que resolve o erro de 'Unknown argument'
  whatYouWillLearn String[] @default([]) 

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  lessons       Lesson[]

  @@map("courses")
}

// 📖 GAVETA DE CONTEÚDO: Lições e Aulas
model Lesson {
  id        String   @id @default(cuid())
  title     String
  slug      String
  videoUrl  String
  duration  String?
  order     Int      @default(0)
  courseId  String
  wpId      Int?     @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  course    Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@map("lessons")
}